# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted (Used on the backend for CORS, e.g. https://automvoice.netlify.app)
APP_URL="MY_APP_URL"

# VITE_API_URL: The URL of your backend. (Used on the frontend, e.g. https://my-backend.onrender.com)
VITE_API_URL="MY_VITE_API_URL"

# ELEVENLABS_API_KEY: Required for ElevenLabs TTS
ELEVENLABS_API_KEY="MY_ELEVENLABS_API_KEY"

# ELEVENLABS_VOICE_ID: Required for ElevenLabs TTS
ELEVENLABS_VOICE_ID="MY_ELEVENLABS_VOICE_ID"

# ── Firebase (client-side) ────────────────────────────────────────────────────
# All VITE_ prefixed vars are exposed to the frontend bundle.
# Get these from Firebase Console → Project Settings → Your apps → SDK setup.
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_PROJECT_ID.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="MY_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="MY_PROJECT_ID.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_SENDER_ID"
VITE_FIREBASE_APP_ID="MY_APP_ID"
